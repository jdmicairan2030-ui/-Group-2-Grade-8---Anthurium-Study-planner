deadlines = [] 
habits = ["Review notes", "Read for 20 minutes", "Practice solving exercises"]  

todo_list = []

break_interval = "Every 60 minutes"  
exercise_reminder = "Exercise at 5:00 PM" 
sleep_reminder = "Sleep at 10:30 PM" 

def add_deadline(): 
    task = input("\nEnter the activity or homework: ")   
    date = input("Enter the deadline (Example: Dec 12): ")
    deadlines.append((task, date))
    print("\nDeadline added.")

def view_deadlines():  
    if not deadlines:
        print("\nNo deadlines added yet.")
    else:
        print("\nUpcoming Deadlines:")
        for task, date in deadlines:
            print(f"  • {task} — due on {date}")

def show_habits():   
    print("\nStudy Habit Reminders:")
    for habit in habits:
        print(f"  - {habit}")

def show_wellness(): 
    print("\nWellness Reminders:")
    print("Take a short break", break_interval)
    print(exercise_reminder)
    print(sleep_reminder)

def add_todo():
    task = input("\nEnter a task for your to-do list: ")
    todo_list.append(task)
    print("\nTask added to your to-do list.")

def view_todo():
    if not todo_list:
        print("\nYour to-do list is empty.")
    else:
        print("\nYour To-Do List:")
        for i, task in enumerate(todo_list, 1):
            print(f"{i}. {task}")

def main():
    while True:
        print("\n---- STUDY PLANNER JOURNAL ----")
        print("[1] Add a deadline")
        print("[2] View deadlines")
        print("[3] Show study habits")
        print("[4] Show wellness reminders")
        print("[5] Add to-do task")
        print("[6] View to-do list")
        print("[7] Exit")

        choice = input("Choose an option: ")

        if choice == "1":
            add_deadline()
        elif choice == "2":
            view_deadlines()
        elif choice == "3":
            show_habits()
        elif choice == "4":
            show_wellness()
        elif choice == "5":
            add_todo()
        elif choice == "6":
            view_todo()
        elif choice == "7":
            print("\nGood luck with your studies.")
            break
        else:
            print("\nInvalid choice, try again.")

if __name__ == "__main__":
    main()
